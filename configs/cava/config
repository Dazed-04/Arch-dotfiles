[general]
framerate = 60
autosens = 1
bars = 0
bar_width = 2
bar_spacing = 1

[input]
method = fifo
source = /tmp/mpd.fifo

[output]
# Required for rmpc to display the visualizer internally
method = raw
raw_target = /dev/stdout
data_format = binary
bit_format = 16bit

[color]
# Using Matugen to create a dynamic gradient
gradient = 1
gradient_count = 8
gradient_color_1 = '#ffb1c3'
gradient_color_2 = '#713344'
gradient_color_3 = '#e4bdc4'
gradient_color_4 = '#5b3f45'
gradient_color_5 = '#edbe92'
gradient_color_6 = '#60401e'
gradient_color_7 = '#ffb4ab'
gradient_color_8 = '#9e8c8f'

[smoothing]
noise_reduction = 77
