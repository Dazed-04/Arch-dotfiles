[general]
framerate = 60
autosens = 1
bars = 0
bar_width = 2
bar_spacing = 1

[input]
method = fifo
source = /tmp/mpd.fifo

[output]
# Required for rmpc to display the visualizer internally
method = raw
raw_target = /dev/stdout
data_format = binary
bit_format = 16bit

[color]
# Using Matugen to create a dynamic gradient
gradient = 1
gradient_count = 8
gradient_color_1 = '#bbc3ff'
gradient_color_2 = '#3a4279'
gradient_color_3 = '#c4c5dd'
gradient_color_4 = '#434559'
gradient_color_5 = '#e6bad7'
gradient_color_6 = '#5d3c54'
gradient_color_7 = '#ffb4ab'
gradient_color_8 = '#90909a'

[smoothing]
noise_reduction = 77
