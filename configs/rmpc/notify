#!/usr/bin/env sh

TMP_DIR="/tmp/rmpc"
mkdir -p "$TMP_DIR"
LRCLIB="https://lrclib.net"
ALBUM_ART_PATH="$TMP_DIR/notification_cover"
DEFAULT_ART_PATH="$TMP_DIR/default_album_art.jpg"

# 1. Handle Album Art & Notification (Synchronous replaces old ones)
rmpc albumart --output "$ALBUM_ART_PATH" || ALBUM_ART_PATH="$DEFAULT_ART_PATH"
notify-send -i "$ALBUM_ART_PATH" -h string:x-canonical-private-synchronous:music-track \
    "${TITLE^^}" "<b>$ARTIST</b>\n<i>$ALBUM</i>"

# 2. Lyrics Logic
if [ "$HAS_LRC" = "false" ]; then
  mkdir -p "$(dirname "$LRC_FILE")"

  # Attempt 1: Exact Match
  RESP=$(curl -s -G -H "Lrclib-Client: rmpc-$VERSION" \
    --data-urlencode "artist_name=$ARTIST" --data-urlencode "track_name=$TITLE" \
    --data-urlencode "album_name=$ALBUM" "$LRCLIB/api/get")
  LYRICS=$(echo "$RESP" | jq -r '.syncedLyrics // .plainLyrics // empty')

  # Attempt 2: Fuzzy Search Fallback
  if [ -z "$LYRICS" ] || [ "$LYRICS" = "null" ]; then
    RESP=$(curl -s -G -H "Lrclib-Client: rmpc-$VERSION" \
      --data-urlencode "q=$ARTIST $TITLE" "$LRCLIB/api/search")
    LYRICS=$(echo "$RESP" | jq -r '.[0].syncedLyrics // .[0].plainLyrics // empty')
  fi

  # 3. Final Output or Placeholder
  {
    echo "[ar:$ARTIST]\n[al:$ALBUM]\n[ti:$TITLE]"
    if [ -n "$LYRICS" ] && [ "$LYRICS" != "null" ]; then
      echo "$LYRICS" | sed -E '/^\[(ar|al|ti):/d'
      MSG="Downloaded lyrics for $TITLE"
      LVL="info"
    else
      i=0
      while [ $i -lt 300 ]; do
        m=$(printf "%02d" $((i / 60)))
        s=$(printf "%02d" $((i % 60)))
        case $((i % 4)) in
          0) echo "[$m:$s.00] ⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏" ;;
          1) echo "[$m:$s.00] ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏ ⠋" ;;
          2) echo "[$m:$s.00] ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏ ⠋ ⠙" ;;
          3) echo "[$m:$s.00] ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏ ⠋ ⠙ ⠹" ;;
        esac
        i=$((i + 1))
      done
    fi
  } > "$LRC_FILE"

  rmpc remote --pid "$PID" indexlrc --path "$LRC_FILE"
fi
