#!/usr/bin/env bash
set -euo pipefail

RENDERER="$HOME/.local/bin/myScripts/media/render-progress.py"
local_music_dir="$HOME/Music"
output_path="$local_music_dir/%(title)s.%(ext)s"
playlist_args=(--no-playlist)
progress_template="%(info.playlist_index)s|%(info.n_entries)s|%(info.title)s|%(progress._percent_str)s|%(progress._speed_str)s|%(progress._eta_str)s|%(progress.downloaded_bytes)s|%(progress.total_bytes)s"

SESSION_DIR="/tmp/get-music-$$"
mkdir -p "$SESSION_DIR"
trap 'rm -rf "$SESSION_DIR"' EXIT

clear_kitty_images() {
  kitty icat --clear 2>/dev/null || true
}

search_and_pick() {
  local query="$1"
  local search_limit=15
  local thumb_cache="$SESSION_DIR/thumbs"
  local ids_file="$SESSION_DIR/ids.txt"
  local thumb_urls_file="$SESSION_DIR/thumb_urls.txt"
  local entries_file="$SESSION_DIR/entries.txt"
  local preview_script="$SESSION_DIR/preview.sh"

  mkdir -p "$thumb_cache"
  : >"$ids_file"
  : >"$thumb_urls_file"

  echo "🔍 Searching YouTube for: $query"

  # Single fast request — gets everything we need
  local raw_results
  raw_results=$(yt-dlp "ytsearch${search_limit}:${query}" \
    --flat-playlist --no-warnings --quiet \
    --print "%(id)s|%(title)s|%(channel)s|%(duration)s|%(thumbnails.0.url)s" \
    2>/dev/null) || {
    echo "❌ Search failed."
    exit 1
  }

  [[ -z "$raw_results" ]] && {
    echo "❌ No results found."
    exit 1
  }

  local entries=()
  local ids=()
  local i=0

  while IFS='|' read -r id title channel duration thumb_url; do
    [[ -z "$id" ]] && continue

    # Format duration mm:ss
    local dur_fmt
    dur_fmt=$(echo "$duration" | awk -F. '{d=int($1); printf "%d:%02d", d/60, d%60}')

    entries+=("$(printf '%02d. %-55s  %-28s  [%s]' $((i + 1)) "$title" "$channel" "$dur_fmt")")
    ids+=("$id")
    echo "$id" >>"$ids_file"
    echo "$thumb_url" >>"$thumb_urls_file"
    ((i++)) || true
  done <<<"$raw_results"

  [[ ${#entries[@]} -eq 0 ]] && {
    echo "❌ No valid results."
    exit 1
  }

  printf '%s\n' "${entries[@]}" >"$entries_file"

  # Pre-fetch first 5 thumbnails in background
  (
    i=0
    while IFS= read -r thumb_url; do
      [[ $i -ge 5 ]] && break
      cached_img="$thumb_cache/${i}.jpg"
      if [[ -n "$thumb_url" && ! -f "$cached_img" ]]; then
        curl -sL "$thumb_url" -o "$cached_img" 2>/dev/null || rm -f "$cached_img"
      fi
      ((i++)) || true
    done <"$thumb_urls_file"
  ) &

  # Preview script: cache hit = instant, miss = fetch on demand
  cat >"$preview_script" <<PREVIEW_EOF
#!/usr/bin/env bash
line="\$1"
idx=\$(echo "\$line" | grep -oP '^\d+' | head -1)
idx=\$((10#\$idx - 1))

thumb_cache="${thumb_cache}"
thumb_urls_file="${thumb_urls_file}"
cached_img="\${thumb_cache}/\${idx}.jpg"

if [[ ! -f "\$cached_img" ]]; then
  thumb_url=\$(sed -n "\$((idx+1))p" "\$thumb_urls_file")
  if [[ -n "\$thumb_url" ]]; then
    curl -sL "\$thumb_url" -o "\$cached_img" 2>/dev/null || rm -f "\$cached_img"
  fi
fi

if [[ -f "\$cached_img" ]]; then
  kitty icat --clear --transfer-mode=file --stdin=no \\
    --place="\${FZF_PREVIEW_COLUMNS}x\${FZF_PREVIEW_LINES}@0x0" \\
    "\$cached_img" 2>/dev/null || true
fi
PREVIEW_EOF
  chmod +x "$preview_script"

  local selected
  selected=$(fzf \
    --prompt="🎵 Pick a track > " \
    --height=90% \
    --layout=reverse \
    --border=rounded \
    --preview="$preview_script {}" \
    --preview-window="right:40%:wrap" \
    --bind="ctrl-c:abort" \
    --bind="esc:abort" \
    <"$entries_file") || {
    clear_kitty_images
    echo "❌ No selection made."
    exit 1
  }

  # Clear thumbnail before proceeding to download
  clear_kitty_images

  [[ -z "$selected" ]] && {
    echo "❌ No selection made."
    exit 1
  }

  local sel_idx
  sel_idx=$(echo "$selected" | grep -oP '^\d+' | head -1)
  sel_idx=$((10#$sel_idx - 1))

  SELECTED_ID="${ids[$sel_idx]}"
  SELECTED_URL="https://www.youtube.com/watch?v=${SELECTED_ID}"
}

do_download() {
  local url="$1"

  if [[ -t 1 ]]; then
    yt-dlp -x --audio-format mp3 --audio-quality 0 --add-metadata \
      --embed-thumbnail "${playlist_args[@]}" \
      -o "$output_path" "$url" \
      --newline --progress \
      --windows-filenames \
      --replace-in-metadata title "^(.+?) - (.+)$" "\2" \
      --replace-in-metadata title "(?i)\(([^)]*(Official|Lyric|Lyrics|Video|Music|4K|1080p|HD|HQ|Audio|Visualizer)[^)]*)\)" "" \
      --replace-in-metadata title "\s{2,}" " " \
      --replace-in-metadata title "^\s+|\s+$" "" \
      --progress-template "$progress_template" \
      --ignore-config --no-warnings |
      python3 -u "$RENDERER"
    status=${PIPESTATUS[1]}
  else
    echo "📡 Non-interactive detected. Streaming raw logs..."
    yt-dlp -x --audio-format mp3 --audio-quality 0 --add-metadata \
      --embed-thumbnail "${playlist_args[@]}" \
      -o "$output_path" "$url" \
      --newline --progress \
      --progress-template "$progress_template"
    status=$?
  fi

  if [[ "$status" -eq 0 ]]; then
    command -v mpc >/dev/null && mpc update >/dev/null 2>&1 || true
  elif [[ "$status" -eq 130 ]]; then
    exit 130
  else
    echo -e "\n❌ Error: Download failed (Exit Code: $status)."
    exit 1
  fi
}

ask_single_or_playlist() {
  echo ""
  echo "  [1] Download this track only"
  echo "  [2] Download full playlist (if available)"
  printf "  Choice [1/2]: "
  read -r choice
  if [[ "$choice" == "2" ]]; then
    playlist_args=(--yes-playlist)
    output_path="$local_music_dir/%(uploader)s/%(playlist_title)s/%(playlist_index)02d - %(title)s.%(ext)s"
  fi
  echo""
}

OPTIND=1
while getopts "ph" opt; do
  case "$opt" in
  p)
    playlist_args=(--yes-playlist)
    output_path="$local_music_dir/%(uploader)s/%(playlist_title)s/%(playlist_index)02d - %(title)s.%(ext)s"
    ;;
  h)
    echo "Usage: get-music [-p] [URL or search terms]"
    echo "  -p        Enable playlist mode upfront"
    echo "  -h        Show this help"
    echo ""
    echo "  With URL:          Downloads directly"
    echo "  With search terms: Searches and lets you pick via fzf"
    echo "  No args:           Prompts for search query"
    exit 0
    ;;
  *)
    echo "Usage: get-music [-p] [URL or search terms]"
    exit 1
    ;;
  esac
done
shift $((OPTIND - 1))

mkdir -p "$local_music_dir"
echo ""

URL="${1:-}"

if [[ -z "$URL" ]]; then
  printf "🎵 Search YouTube: "
  read -r query
  [[ -z "$query" ]] && {
    echo "❌ No query provided."
    exit 1
  }
  SELECTED_ID=""
  SELECTED_URL=""
  search_and_pick "$query"
  ask_single_or_playlist
  do_download "$SELECTED_URL"

elif [[ "$URL" =~ ^https?:// ]]; then
  do_download "$URL"

else
  query="$*"
  SELECTED_ID=""
  SELECTED_URL=""
  echo""
  search_and_pick "$query"
  ask_single_or_playlist
  do_download "$SELECTED_URL"
fi
